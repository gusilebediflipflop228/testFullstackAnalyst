<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn">

  <collaboration id="Collaboration_1">
    <participant id="Participant_User" name="Пользователь офиса" processRef="Process_User"/>
    <participant id="Participant_TechSupport" name="1-я линия ТП" processRef="Process_TechSupport"/>
    <participant id="Participant_Supply" name="Отдел снабжения" processRef="Process_Supply"/>
    <participant id="Participant_Logistics" name="Логистика" processRef="Process_Logistics"/>
    <participant id="Participant_Supplier" name="Поставщик" processRef="Process_Supplier"/>

    <messageFlow id="MF_UserToTS" sourceRef="Task_UserMakeRequest" targetRef="Event_TSReceiveRequest" name="Заявка на оборудование"/>
    <messageFlow id="MF_TS_GetNumber" sourceRef="Task_CreateTicket" targetRef="Task_UserGetNumber" name="Номер обращения"/>
    <messageFlow id="MF_TS_ToSupply" sourceRef="Task_CreateRequestSupply" targetRef="Event_SupplyReceiveRequest" name="Заявка в Системе №2"/>
    <messageFlow id="MF_Supply_Logistics" sourceRef="Task_CallLogistics" targetRef="Event_LogisticsReceive" name="Вызов логистики"/>
    <messageFlow id="MF_Supply_Order" sourceRef="Task_MakePurchaseRequest" targetRef="Event_SupplierReceiveOrder" name="Заявка на закупку"/>
    <messageFlow id="MF_Supplier_Deliver" sourceRef="Task_DeliverEquipment" targetRef="Event_SupplyReceiveEquipment" name="Поставка оборудования"/>
    <messageFlow id="MF_Logistics_ToTS" sourceRef="Task_SendToTechSupport_log" targetRef="Event_TechSupportReceiveEquipment" name="Оборудование ТП"/>
    <messageFlow id="MF_TS_GiveUser" sourceRef="Task_GiveEquipment" targetRef="Event_UserReceiveEquipment" name="Выдача оборудования"/>
  </collaboration>

  <!-- Пользователь офиса -->
  <process id="Process_User" isExecutable="false">
    <startEvent id="Event_UserNeed" name="Нужно оборудование">
      <outgoing>Flow_User_1</outgoing>
    </startEvent>
    <task id="Task_UserMakeRequest" name="Отправить заявку (почта/телефон)">
      <incoming>Flow_User_1</incoming>
      <outgoing>Flow_User_2</outgoing>
    </task>
    <task id="Task_UserGetNumber" name="Получить номер обращения">
      <incoming>Flow_User_2</incoming>
      <outgoing>Flow_User_3</outgoing>
    </task>
    <receiveEvent id="Event_UserReceiveEquipment" name="Получить оборудование">
      <incoming>Flow_User_3</incoming>
      <outgoing>Flow_User_4</outgoing>
    </receiveEvent>
    <task id="Task_UserRate" name="Оценить сервис ТП">
      <incoming>Flow_User_4</incoming>
      <outgoing>Flow_User_5</outgoing>
    </task>
    <endEvent id="Event_UserEnd" name="Завершено">
      <incoming>Flow_User_5</incoming>
    </endEvent>

    <sequenceFlow id="Flow_User_1" sourceRef="Event_UserNeed" targetRef="Task_UserMakeRequest"/>
    <sequenceFlow id="Flow_User_2" sourceRef="Task_UserMakeRequest" targetRef="Task_UserGetNumber"/>
    <sequenceFlow id="Flow_User_3" sourceRef="Task_UserGetNumber" targetRef="Event_UserReceiveEquipment"/>
    <sequenceFlow id="Flow_User_4" sourceRef="Event_UserReceiveEquipment" targetRef="Task_UserRate"/>
    <sequenceFlow id="Flow_User_5" sourceRef="Task_UserRate" targetRef="Event_UserEnd"/>
  </process>

  <!-- 1-я линия техподдержки -->
  <process id="Process_TechSupport" isExecutable="false">
    <startEvent id="Event_TSReceiveRequest" name="Получить заявку от пользователя">
      <outgoing>Flow_TS_1</outgoing>
    </startEvent>
    <task id="Task_CreateTicket" name="Создать обращение в Системе №1 (присвоить номер)">
      <incoming>Flow_TS_1</incoming>
      <outgoing>Flow_TS_2</outgoing>
    </task>
    <task id="Task_CreateRequestSupply" name="Создать заявку на оборудование в Системе №2 (отделу снабжения)">
      <incoming>Flow_TS_2</incoming>
      <outgoing>Flow_TS_3</outgoing>
    </task>
    <receiveEvent id="Event_TechSupportReceiveEquipment" name="Получить оборудование от логистики">
      <incoming>Flow_TS_3</incoming>
      <outgoing>Flow_TS_4</outgoing>
    </receiveEvent>
    <task id="Task_GiveEquipment" name="Выдать оборудование пользователю">
      <incoming>Flow_TS_4</incoming>
      <outgoing>Flow_TS_5</outgoing>
    </task>
    <parallelGateway id="GW_CloseParallel" name="">
      <incoming>Flow_TS_5</incoming>
      <outgoing>Flow_TS_6</outgoing>
      <outgoing>Flow_TS_7</outgoing>
    </parallelGateway>
    <task id="Task_CloseRequestS1" name="Закрыть заявку пользователя в Системе №1">
      <incoming>Flow_TS_6</incoming>
      <outgoing>Flow_TS_8</outgoing>
    </task>
    <task id="Task_CloseRequestS2" name="Закрыть заявку в Системе №2">
      <incoming>Flow_TS_7</incoming>
      <outgoing>Flow_TS_9</outgoing>
    </task>
    <parallelGateway id="GW_CloseJoin" name="">
      <incoming>Flow_TS_8</incoming>
      <incoming>Flow_TS_9</incoming>
      <outgoing>Flow_TS_10</outgoing>
    </parallelGateway>
    <endEvent id="Event_TSEnd" name="Заявка закрыта">
      <incoming>Flow_TS_10</incoming>
    </endEvent>

    <sequenceFlow id="Flow_TS_1" sourceRef="Event_TSReceiveRequest" targetRef="Task_CreateTicket"/>
    <sequenceFlow id="Flow_TS_2" sourceRef="Task_CreateTicket" targetRef="Task_CreateRequestSupply"/>
    <sequenceFlow id="Flow_TS_3" sourceRef="Task_CreateRequestSupply" targetRef="Event_TechSupportReceiveEquipment"/>
    <sequenceFlow id="Flow_TS_4" sourceRef="Event_TechSupportReceiveEquipment" targetRef="Task_GiveEquipment"/>
    <sequenceFlow id="Flow_TS_5" sourceRef="Task_GiveEquipment" targetRef="GW_CloseParallel"/>
    <sequenceFlow id="Flow_TS_6" sourceRef="GW_CloseParallel" targetRef="Task_CloseRequestS1"/>
    <sequenceFlow id="Flow_TS_7" sourceRef="GW_CloseParallel" targetRef="Task_CloseRequestS2"/>
    <sequenceFlow id="Flow_TS_8" sourceRef="Task_CloseRequestS1" targetRef="GW_CloseJoin"/>
    <sequenceFlow id="Flow_TS_9" sourceRef="Task_CloseRequestS2" targetRef="GW_CloseJoin"/>
    <sequenceFlow id="Flow_TS_10" sourceRef="GW_CloseJoin" targetRef="Event_TSEnd"/>
  </process>

  <!-- Отдел снабжения -->
  <process id="Process_Supply" isExecutable="false">
    <startEvent id="Event_SupplyReceiveRequest" name="Получить заявку (уведомление + кабинет Системы №2)">
      <outgoing>Flow_Sup_1</outgoing>
    </startEvent>
    <task id="Task_CheckAvailability" name="Проверить наличие оборудования в Системе №3">
      <incoming>Flow_Sup_1</incoming>
      <outgoing>Flow_Sup_2</outgoing>
    </task>
    <exclusiveGateway id="GW_Availability" name="Оборудование есть?">
      <incoming>Flow_Sup_2</incoming>
      <outgoing>Flow_Sup_Yes</outgoing>
      <outgoing>Flow_Sup_No</outgoing>
    </exclusiveGateway>

    <!-- Ветка: оборудование есть -->
    <task id="Task_CallLogistics" name="Вызвать логистику">
      <incoming>Flow_Sup_Yes</incoming>
      <outgoing>Flow_Sup_3</outgoing>
    </task>
    <task id="Task_SendToTechSupport" name="Отправить оборудование первой линии ТП">
      <incoming>Flow_Sup_3</incoming>
      <outgoing>Flow_Sup_EndYes</outgoing>
    </task>
    <endEvent id="Event_SupplyEndYes" name="Оборудование передано ТП">
      <incoming>Flow_Sup_EndYes</incoming>
    </endEvent>

    <!-- Ветка: оборудование нет -->
    <task id="Task_MakePurchaseRequest" name="Сделать заявку на закупку поставщику (через почту)">
      <incoming>Flow_Sup_No</incoming>
      <outgoing>Flow_Sup_4</outgoing>
    </task>
    <task id="Task_WaitSupplier" name="Ждать поставку от поставщика">
      <incoming>Flow_Sup_4</incoming>
      <outgoing>Flow_Sup_5</outgoing>
    </task>
    <receiveEvent id="Event_SupplyReceiveEquipment" name="Принять оборудование от поставщика (провести в Системе №3)">
      <incoming>Flow_Sup_5</incoming>
      <outgoing>Flow_Sup_6</outgoing>
    </receiveEvent>
    <task id="Task_CallLogisticsAfter" name="Вызвать логистику">
      <incoming>Flow_Sup_6</incoming>
      <outgoing>Flow_Sup_7</outgoing>
    </task>
    <task id="Task_SendToTSPurchase" name="Передать оборудование техподдержке">
      <incoming>Flow_Sup_7</incoming>
      <outgoing>Flow_Sup_EndNo</outgoing>
    </task>
    <endEvent id="Event_SupplyEndNo" name="Оборудование передано ТП">
      <incoming>Flow_Sup_EndNo</incoming>
    </endEvent>

    <sequenceFlow id="Flow_Sup_1" sourceRef="Event_SupplyReceiveRequest" targetRef="Task_CheckAvailability"/>
    <sequenceFlow id="Flow_Sup_2" sourceRef="Task_CheckAvailability" targetRef="GW_Availability"/>
    <sequenceFlow id="Flow_Sup_Yes" name="Да" sourceRef="GW_Availability" targetRef="Task_CallLogistics"/>
    <sequenceFlow id="Flow_Sup_No" name="Нет" sourceRef="GW_Availability" targetRef="Task_MakePurchaseRequest"/>
    <sequenceFlow id="Flow_Sup_3" sourceRef="Task_CallLogistics" targetRef="Task_SendToTechSupport"/>
    <sequenceFlow id="Flow_Sup_EndYes" sourceRef="Task_SendToTechSupport" targetRef="Event_SupplyEndYes"/>
    <sequenceFlow id="Flow_Sup_4" sourceRef="Task_MakePurchaseRequest" targetRef="Task_WaitSupplier"/>
    <sequenceFlow id="Flow_Sup_5" sourceRef="Task_WaitSupplier" targetRef="Event_SupplyReceiveEquipment"/>
    <sequenceFlow id="Flow_Sup_6" sourceRef="Event_SupplyReceiveEquipment" targetRef="Task_CallLogisticsAfter"/>
    <sequenceFlow id="Flow_Sup_7" sourceRef="Task_CallLogisticsAfter" targetRef="Task_SendToTSPurchase"/>
    <sequenceFlow id="Flow_Sup_EndNo" sourceRef="Task_SendToTSPurchase" targetRef="Event_SupplyEndNo"/>
  </process>

  <!-- Логистика -->
  <process id="Process_Logistics" isExecutable="false">
    <receiveEvent id="Event_LogisticsReceive" name="Получить вызов от снабжения">
      <outgoing>Flow_Log_1</outgoing>
    </receiveEvent>
    <task id="Task_SendToTechSupport_log" name="Доставить оборудование техподдержке">
      <incoming>Flow_Log_1</incoming>
      <outgoing>Flow_Log_2</outgoing>
    </task>
    <endEvent id="Event_LogisticsEnd" name="Доставлено">
      <incoming>Flow_Log_2</incoming>
    </endEvent>

    <sequenceFlow id="Flow_Log_1" sourceRef="Event_LogisticsReceive" targetRef="Task_SendToTechSupport_log"/>
    <sequenceFlow id="Flow_Log_2" sourceRef="Task_SendToTechSupport_log" targetRef="Event_LogisticsEnd"/>
  </process>

  <!-- Поставщик -->
  <process id="Process_Supplier" isExecutable="false">
    <receiveEvent id="Event_SupplierReceiveOrder" name="Получить заявку на закупку">
      <outgoing>Flow_Suppl_1</outgoing>
    </receiveEvent>
    <task id="Task_DeliverEquipment" name="Привезти оборудование">
      <incoming>Flow_Suppl_1</incoming>
      <outgoing>Flow_Suppl_2</outgoing>
    </task>
    <endEvent id="Event_SupplierEnd" name="Поставка завершена">
      <incoming>Flow_Suppl_2</incoming>
    </endEvent>

    <sequenceFlow id="Flow_Suppl_1" sourceRef="Event_SupplierReceiveOrder" targetRef="Task_DeliverEquipment"/>
    <sequenceFlow id="Flow_Suppl_2" sourceRef="Task_DeliverEquipment" targetRef="Event_SupplierEnd"/>
  </process>

  <!-- BPMN Diagram -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <!-- Пул: Пользователь офиса -->
      <bpmndi:BPMNShape id="Participant_User_di" bpmnElement="Participant_User" isHorizontal="true">
        <dc:Bounds x="160" y="340" width="1200" height="180"/>
      </bpmndi:BPMNShape>
      
      <!-- Пул: 1-я линия ТП -->
      <bpmndi:BPMNShape id="Participant_TechSupport_di" bpmnElement="Participant_TechSupport" isHorizontal="true">
        <dc:Bounds x="160" y="120" width="1200" height="180"/>
      </bpmndi:BPMNShape>
      
      <!-- Пул: Отдел снабжения -->
      <bpmndi:BPMNShape id="Participant_Supply_di" bpmnElement="Participant_Supply" isHorizontal="true">
        <dc:Bounds x="160" y="-120" width="1200" height="200"/>
      </bpmndi:BPMNShape>
      
      <!-- Пул: Логистика -->
      <bpmndi:BPMNShape id="Participant_Logistics_di" bpmnElement="Participant_Logistics" isHorizontal="true">
        <dc:Bounds x="160" y="-380" width="600" height="120"/>
      </bpmndi:BPMNShape>
      
      <!-- Пул: Поставщик -->
      <bpmndi:BPMNShape id="Participant_Supplier_di" bpmnElement="Participant_Supplier" isHorizontal="true">
        <dc:Bounds x="160" y="-560" width="600" height="120"/>
      </bpmndi:BPMNShape>

      <!-- Элементы: Пользователь -->
      <bpmndi:BPMNShape id="Event_UserNeed_di" bpmnElement="Event_UserNeed">
        <dc:Bounds x="230" y="412" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UserMakeRequest_di" bpmnElement="Task_UserMakeRequest">
        <dc:Bounds x="310" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UserGetNumber_di" bpmnElement="Task_UserGetNumber">
        <dc:Bounds x="470" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_UserReceiveEquipment_di" bpmnElement="Event_UserReceiveEquipment">
        <dc:Bounds x="630" y="412" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UserRate_di" bpmnElement="Task_UserRate">
        <dc:Bounds x="710" y="390" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_UserEnd_di" bpmnElement="Event_UserEnd">
        <dc:Bounds x="870" y="412" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Элементы: ТП -->
      <bpmndi:BPMNShape id="Event_TSReceiveRequest_di" bpmnElement="Event_TSReceiveRequest">
        <dc:Bounds x="230" y="192" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateTicket_di" bpmnElement="Task_CreateTicket">
        <dc:Bounds x="310" y="170" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateRequestSupply_di" bpmnElement="Task_CreateRequestSupply">
        <dc:Bounds x="490" y="170" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_TechSupportReceiveEquipment_di" bpmnElement="Event_TechSupportReceiveEquipment">
        <dc:Bounds x="690" y="192" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GiveEquipment_di" bpmnElement="Task_GiveEquipment">
        <dc:Bounds x="770" y="170" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_CloseParallel_di" bpmnElement="GW_CloseParallel">
        <dc:Bounds x="930" y="185" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CloseRequestS1_di" bpmnElement="Task_CloseRequestS1">
        <dc:Bounds x="1020" y="140" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CloseRequestS2_di" bpmnElement="Task_CloseRequestS2">
        <dc:Bounds x="1020" y="220" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_CloseJoin_di" bpmnElement="GW_CloseJoin">
        <dc:Bounds x="1200" y="185" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_TSEnd_di" bpmnElement="Event_TSEnd">
        <dc:Bounds x="1290" y="192" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Элементы: Снабжение -->
      <bpmndi:BPMNShape id="Event_SupplyReceiveRequest_di" bpmnElement="Event_SupplyReceiveRequest">
        <dc:Bounds x="230" y="-48" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckAvailability_di" bpmnElement="Task_CheckAvailability">
        <dc:Bounds x="310" y="-70" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Availability_di" bpmnElement="GW_Availability">
        <dc:Bounds x="520" y="-55" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CallLogistics_di" bpmnElement="Task_CallLogistics">
        <dc:Bounds x="620" y="-100" width="120" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendToTechSupport_di" bpmnElement="Task_SendToTechSupport">
        <dc:Bounds x="780" y="-100" width="140" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_SupplyEndYes_di" bpmnElement="Event_SupplyEndYes">
        <dc:Bounds x="960" y="-90" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_MakePurchaseRequest_di" bpmnElement="Task_MakePurchaseRequest">
        <dc:Bounds x="620" y="10" width="160" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_WaitSupplier_di" bpmnElement="Task_WaitSupplier">
        <dc:Bounds x="820" y="10" width="120" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_SupplyReceiveEquipment_di" bpmnElement="Event_SupplyReceiveEquipment">
        <dc:Bounds x="980" y="22" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CallLogisticsAfter_di" bpmnElement="Task_CallLogisticsAfter">
        <dc:Bounds x="1050" y="10" width="120" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendToTSPurchase_di" bpmnElement="Task_SendToTSPurchase">
        <dc:Bounds x="1210" y="10" width="140" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_SupplyEndNo_di" bpmnElement="Event_SupplyEndNo">
        <dc:Bounds x="1390" y="22" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Элементы: Логистика -->
      <bpmndi:BPMNShape id="Event_LogisticsReceive_di" bpmnElement="Event_LogisticsReceive">
        <dc:Bounds x="230" y="-348" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendToTechSupport_log_di" bpmnElement="Task_SendToTechSupport_log">
        <dc:Bounds x="310" y="-370" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_LogisticsEnd_di" bpmnElement="Event_LogisticsEnd">
        <dc:Bounds x="490" y="-348" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Элементы: Поставщик -->
      <bpmndi:BPMNShape id="Event_SupplierReceiveOrder_di" bpmnElement="Event_SupplierReceiveOrder">
        <dc:Bounds x="230" y="-528" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DeliverEquipment_di" bpmnElement="Task_DeliverEquipment">
        <dc:Bounds x="310" y="-550" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_SupplierEnd_di" bpmnElement="Event_SupplierEnd">
        <dc:Bounds x="490" y="-528" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Sequence Flow: Пользователь -->
      <bpmndi:BPMNEdge id="Flow_User_1_di" bpmnElement="Flow_User_1">
        <di:waypoint x="266" y="430"/>
        <di:waypoint x="310" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_User_2_di" bpmnElement="Flow_User_2">
        <di:waypoint x="430" y="430"/>
        <di:waypoint x="470" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_User_3_di" bpmnElement="Flow_User_3">
        <di:waypoint x="590" y="430"/>
        <di:waypoint x="630" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_User_4_di" bpmnElement="Flow_User_4">
        <di:waypoint x="666" y="430"/>
        <di:waypoint x="710" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_User_5_di" bpmnElement="Flow_User_5">
        <di:waypoint x="830" y="430"/>
        <di:waypoint x="870" y="430"/>
      </bpmndi:BPMNEdge>

      <!-- Sequence Flow: ТП -->
      <bpmndi:BPMNEdge id="Flow_TS_1_di" bpmnElement="Flow_TS_1">
        <di:waypoint x="266" y="210"/>
        <di:waypoint x="310" y="210"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TS_2_di" bpmnElement="Flow_TS_2">
        <di:waypoint x="450" y="210"/>
        <di:waypoint x="490" y="210"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TS_3_di" bpmnElement="Flow_TS_3">
        <di:waypoint x="640" y="210"/>
        <di:waypoint x="690" y="210"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TS_4_di" bpmnElement="Flow_TS_4">
        <di:waypoint x="726" y="210"/>
        <di:waypoint x="770" y="210"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TS_5_di" bpmnElement="Flow_TS_5">
        <di:waypoint x="890" y="210"/>
        <di:waypoint x="930" y="210"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TS_6_di" bpmnElement="Flow_TS_6">
        <di:waypoint x="955" y="210"/>
        <di:waypoint x="1020" y="210"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TS_7_di" bpmnElement="Flow_TS_7">
        <di:waypoint x="955" y="235"/>
        <di:waypoint x="955" y="250"/>
        <di:waypoint x="1020" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TS_8_di" bpmnElement="Flow_TS_8">
